{
  "manifest_version": 3,
  "name": "Meet Caption Sender",
  "version": "1.0.0",
  "description": "Capture finalized Google Meet captions and send them to localhost:3000",
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
